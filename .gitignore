# ============================================
# NutriDiabetes Perú — .gitignore
# ============================================

# ── Variables de entorno (SECRETOS) ──
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# ── Dependencias ──
node_modules/
venv/
.venv/
__pycache__/
*.pyc
*.pyo

# ── Next.js ──
.next/
out/

# ── Build ──
build/
dist/

# ── Logs ──
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ── OS ──
.DS_Store
Thumbs.db
Desktop.ini

# ── IDE ──
.vscode/
.idea/
*.swp
*.swo
*~

# ── PDFs pesados (datos fuente) ──
scripts/*.pdf
scripts/data/*.pdf

# ── PWA generado ──
public/sw.js
public/workbox-*.js
public/sw.js.map

# ── Coverage ──
coverage/
.nyc_output/

# ── Misc ──
*.bak
*.tmp
nul